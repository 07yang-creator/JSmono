{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/parse-pdf",      "dest": "/api/parse-pdf.py"      },
    { "src": "/api/generate-flyer", "dest": "/api/generate-flyer.py" },
    { "src": "/(.*)",               "dest": "/public/$1"             }
  ],
  "env": {
    "FONT_PATH": "/var/task/fonts/DroidSansFallbackFull.ttf"
  }
}
