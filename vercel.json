{
  "framework": null,
  "outputDirectory": "public",
  "buildCommand": "python3 scripts/download_fonts.py",
  "functions": {
    "api/generate-flyer.py": {
      "maxDuration": 60
    },
    "api/parse-pdf.py": {
      "maxDuration": 30
    },
    "api/monospages-admin.py": {
      "maxDuration": 30
    },
    "api/monospages-config.py": {
      "maxDuration": 30
    },
    "api/monospages-upload.py": {
      "maxDuration": 30
    },
    "api/monospages-field-record.py": {
      "maxDuration": 30
    },
    "api/monospages-analysis-record.py": {
      "maxDuration": 30
    }
  },
  "env": {
    "FONT_PATH": "/var/task/fonts/DroidSansFallbackFull.ttf",
    "NOTO_REGULAR_PATH": "/var/task/fonts/NotoSansJP-Regular.ttf",
    "NOTO_BOLD_PATH": "/var/task/fonts/NotoSansJP-Bold.ttf"
  }
}
