{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/parse-pdf.py":      { "runtime": "python3.12" },
    "api/generate-flyer.py": { "runtime": "python3.12" }
  },
  "rewrites": [
    { "source": "/api/parse-pdf",      "destination": "/api/parse-pdf.py"      },
