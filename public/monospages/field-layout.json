{
  "_comment": "Source of truth for property page field layout. Edit this file to change which fields are basic/extended, their order, and section groupings. The admin page reads and writes this file.",
  "_types": {
    "basic": "Always visible to all tiers (red-marked in sheet)",
    "extended": "Collapsed by default; visible to viewer_premium+ when expanded",
    "input": "Editable by worker/admin; read-only to viewer_premium",
    "media": "Photo/video assets from Google Drive; visible to viewer_premium+"
  },
  "_tiers": ["viewer_basic", "viewer_premium", "worker", "admin"],

  "page_sections": [
    {
      "id": "mono_data",
