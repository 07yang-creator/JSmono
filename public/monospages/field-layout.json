        {
          "id": "second_assessment",
          "title": "二判",
          "fields": [
            { "name": "二判备注",     "type": "input",    "sheet_row": 109, "format": "text_long" }
          ]
        },
        {
          "id": "opportunity",
          "title": "机会分析",
          "fields": [
            { "name": "关注级别",     "type": "input",    "sheet_row": 110, "format": "select", "options": ["A", "B", "C", "D"] },
            { "name": "要点",         "type": "input",    "sheet_row": 111, "format": "text_long" },
            { "name": "处置方式",     "type": "input",    "sheet_row": 112, "format": "select", "options": ["修缮出租", "修整转售", "其他"] },
