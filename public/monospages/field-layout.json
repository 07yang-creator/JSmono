            { "name": "修整转售",     "type": "input",    "sheet_row": 116, "format": "currency_jpy" },
            { "name": "持有时间",     "type": "input",    "sheet_row": 117, "format": "text" },
            { "name": "转售价格",     "type": "input",    "sheet_row": 118, "format": "currency_jpy" },
            { "name": "转售收益",     "type": "input",    "sheet_row": 119, "format": "currency_jpy" },
            { "name": "转售收益年化", "type": "input",    "sheet_row": 120, "format": "percent" },
            { "name": "可行入扎价格", "type": "input",    "sheet_row": 122, "format": "currency_jpy" },
