    {
      "id": "field_investigation",
      "title": "现地调查",
      "min_tier": "viewer_premium",
      "subsections": [
        {
          "id": "media",
          "title": "媒体库",
          "fields": [
            { "name": "照片",         "type": "media",    "sheet_row": null, "format": "image_gallery", "drive_subfolder": true },
            { "name": "视频",         "type": "media",    "sheet_row": null, "format": "video_gallery", "drive_subfolder": true },
            { "name": "上传入口",     "type": "media",    "sheet_row": null, "format": "upload_form",   "min_tier": "worker" }
          ]
        },
        {
          "id": "field_comments",
          "title": "现状调查备注",
          "fields": [
            { "name": "现场考察",     "type": "media",    "sheet_row": 95,  "format": "text_long" },
            { "name": "周边商业",     "type": "media",    "sheet_row": 96,  "format": "text_long" },
            { "name": "公共设施",     "type": "media",    "sheet_row": 97,  "format": "text_long" },
            { "name": "噪音",         "type": "media",    "sheet_row": 98,  "format": "text_long" }
          ]
        }
      ]
    },

    {
